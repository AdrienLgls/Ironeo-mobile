{
  "cli": { "version": ">= 14.0.0" },
  "extra": {
    "eas": {
      "projectId": "YOUR_EAS_PROJECT_ID"
    }
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" }
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
